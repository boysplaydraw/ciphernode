# CipherNode Sunucu Yapılandırması
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun

# ── Sunucu ──────────────────────────────────────────────────
PORT=5000
HOST=0.0.0.0
NODE_ENV=production

# ── Veritabanı (ZORUNLU) ────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/ciphernode

# ── SSL / HTTPS ──────────────────────────────────────────────
# HTTPS=false          → HTTP modu (port 5000)
# SSL_DOMAIN=          → Boş bırakınca self-signed sertifika üretilir
# SSL_DOMAIN=example.com → Let's Encrypt sertifikası kullanılır
HTTPS=false
# SSL_DOMAIN=relay.example.com
# SSL_EMAIL=admin@example.com
# SSL_PORT=443
# HTTP_REDIRECT_PORT=80

# ── Dosya & Mesaj Limitleri ──────────────────────────────────
# MESSAGE_TTL_MS=86400000    # 24 saat
# FILE_TTL_MS=86400000       # 24 saat
# MAX_FILE_SIZE_MB=100
# MAX_FILE_DOWNLOADS=10

# ── Tor (opsiyonel) ──────────────────────────────────────────
# TOR_ENABLED=true
# ONION_ADDRESS=youraddress.onion

# ── Expo (geliştirme) ────────────────────────────────────────
# EXPO_PUBLIC_SERVER_URL=https://your-server.com
