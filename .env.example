# ============================================================
# CipherNode — Ortam Değişkenleri
# Kullanım:
#   1. Bu dosyayı .env olarak kopyalayın: cp .env.example .env
#   2. Değerleri doldurun
#   3. .env dosyasını asla git'e commit ETMEYİN (zaten .gitignore'da)
# ============================================================

# ────────────────────────────────────────────────────────────
# SUNUCU (server/ dizini)
# ────────────────────────────────────────────────────────────

# Sunucunun dinleyeceği port (varsayılan: 5000)
PORT=5000

# Sunucunun bind adresi
#   0.0.0.0 = her ağdan erişilebilir (Docker, Termux, LAN)
#   127.0.0.1 = sadece localhost (nginx reverse proxy arkasında kullanın)
HOST=0.0.0.0

# Ortam (development = detaylı log, production = sadece olaylar)
NODE_ENV=production

# Dosya paylaşımı ayarları
MAX_FILE_SIZE_MB=100        # Maksimum dosya boyutu (MB)
MAX_FILE_DOWNLOADS=10       # Dosya başına maksimum indirme sayısı
FILE_TTL_MS=86400000        # Dosya saklama süresi (ms, varsayılan: 24 saat)
MESSAGE_TTL_MS=86400000     # Mesaj saklama süresi (ms, varsayılan: 24 saat)

# Tor Hidden Service — setup-tor-hidden-service.sh çalıştırıldıktan sonra doldurulur
# ONION_ADDRESS=abc123def456.onion

# AWS / Google Cloud / production proxy
# Reverse proxy (nginx, ALB, Cloud Run) arkasında çalışırken bu değeri ayarlayın
# TRUST_PROXY=1


# ────────────────────────────────────────────────────────────
# EXPO CLIENT (client/ dizini)
# Bu değişkenler uygulama derleme zamanında gömülür.
# Değiştirince yeniden build gerekir: eas build veya expo export
# ────────────────────────────────────────────────────────────

# Uygulamanın varsayılan olarak bağlanacağı sunucu URL'si.
# Bu değeri kendi sunucunuzun adresiyle doldurun.
# Kullanıcılar istedikleri zaman farklı bir sunucu girebilir.
#
# Örnekler:
#   https://relay.example.com          (SSL + domain — önerilen)
#   https://cipher.duckdns.org:5000   (DuckDNS + port forwarding)
#   https://xxxx.ngrok.io             (ngrok — test için)
#   http://192.168.1.10:5000          (sadece LAN — SSL olmadan)
#   http://abc123.onion               (Tor hidden service)
#
EXPO_PUBLIC_SERVER_URL=https://your-server.example.com

# Alternatif: sadece domain (port 5000 varsayılır)
# EXPO_PUBLIC_DOMAIN=relay.example.com


# ────────────────────────────────────────────────────────────
# SSL — Let's Encrypt (scripts/setup-ssl.sh tarafından kullanılır)
# ────────────────────────────────────────────────────────────

# SSL_DOMAIN=relay.example.com
# SSL_EMAIL=admin@example.com


# ────────────────────────────────────────────────────────────
# DuckDNS (scripts/setup-duckdns.sh tarafından kullanılır)
# ────────────────────────────────────────────────────────────

# DUCKDNS_DOMAIN=ciphernode-relay    (sadece subdomain, .duckdns.org olmadan)
# DUCKDNS_TOKEN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
