# ╔══════════════════════════════════════════════════════════════╗
# ║         CipherNode — Ortam Değişkenleri Şablonu              ║
# ║                                                              ║
# ║  Kullanım:                                                   ║
# ║    cp .env.example .env                                      ║
# ║    (ardından .env dosyasını düzenleyin)                      ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Sunucu ──────────────────────────────────────────────────────
PORT=5000
HOST=0.0.0.0
NODE_ENV=production

# ── Veritabanı ──────────────────────────────────────────────────
# Docker Compose kullanıyorsanız bu değeri olduğu gibi bırakın.
# Harici bir veritabanı kullanıyorsanız kendi bağlantı adresinizi girin.
DATABASE_URL=postgresql://ciphernode:ciphernode_secret@db:5432/ciphernode

# Docker Compose'daki PostgreSQL şifresi (db ve relay servisleri bu değeri paylaşır)
DB_PASSWORD=ciphernode_secret

# ── SSL / HTTPS ──────────────────────────────────────────────────
# Seçenek 1 — HTTP modu (geliştirme veya reverse proxy arkasında)
HTTPS=false

# Seçenek 2 — Self-signed sertifika (otomatik oluşturulur, tarayıcı uyarı verir)
# HTTPS=true

# Seçenek 3 — Let's Encrypt (gerçek domain gerekir)
# HTTPS=true
# SSL_DOMAIN=relay.example.com
# SSL_EMAIL=admin@example.com
# SSL_PORT=443
# HTTP_REDIRECT_PORT=80

# ── Mesaj & Dosya Limitleri ──────────────────────────────────────
# MESSAGE_TTL_MS=86400000     # Mesaj ömrü: 24 saat (ms cinsinden)
# FILE_TTL_MS=86400000        # Dosya ömrü: 24 saat (ms cinsinden)
# MAX_FILE_SIZE_MB=100        # Maksimum dosya boyutu (MB)
# MAX_FILE_DOWNLOADS=10       # Dosya başına maksimum indirme sayısı

# ── Tor (opsiyonel) ──────────────────────────────────────────────
# TOR_ENABLED=true
# ONION_ADDRESS=your_address.onion

# ── Geliştirme ───────────────────────────────────────────────────
# EXPO_PUBLIC_SERVER_URL=https://your-server.com
