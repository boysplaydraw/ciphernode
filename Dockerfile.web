# ╔══════════════════════════════════════════════════════════════╗
# ║           CipherNode — Web App Dockerfile                    ║
# ║                                                              ║
# ║  Expo web uygulamasını derler ve nginx ile servis eder.      ║
# ║  Relay sunucusunun önünde API proxy olarak çalışır.          ║
# ║                                                              ║
# ║  Mimari:                                                     ║
# ║    Tarayıcı → :8080 (nginx)                                  ║
# ║      /          → Expo SPA (static)                          ║
# ║      /api/*     → relay:5000 (proxy)                         ║
# ║      /socket.io → relay:5000 (proxy, WebSocket)              ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Aşama 1: Expo web derle ────────────────────────────────────
FROM node:20-alpine AS builder

WORKDIR /app

# Bağımlılıkları önce kopyala (katman cache için)
COPY package*.json ./
RUN npm ci

# Uygulama kaynak kodunu kopyala
COPY . .

# EXPO_PUBLIC_SERVER_URL boş bırakılıyor:
# getApiUrl() → window.location.origin kullanır → nginx proxy üzerinden otomatik çalışır
RUN npx expo export --platform web --output-dir /app/web-dist 2>&1 | tail -5

# ── Aşama 2: Nginx ile servis et ──────────────────────────────
FROM nginx:1.27-alpine AS runner

# Özel nginx yapılandırması
COPY nginx/docker-web.conf /etc/nginx/conf.d/default.conf

# Derlenmiş web uygulamasını kopyala
COPY --from=builder /app/web-dist /usr/share/nginx/html

# Nginx varsayılan ana sayfasını kaldır
RUN rm -f /usr/share/nginx/html/50x.html

EXPOSE 8080

# Sağlık kontrolü
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://localhost:8080/ || exit 1

CMD ["nginx", "-g", "daemon off;"]
