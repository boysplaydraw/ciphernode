{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CipherNode",
  "version": "0.1.0",
  "identifier": "site.ciphernode.desktop",
  "build": {
    "beforeDevCommand": "npm --prefix ../.. run web:dev",
    "devUrl": "http://localhost:8081",
    "beforeBuildCommand": "npm --prefix ../.. run electron:build:web",
    "frontendDist": "../../../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CipherNode",
        "width": 1200,
        "height": 800,
        "minWidth": 400,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:* http://127.0.0.1:* ws://localhost:* ws://127.0.0.1:* https://cipher-node.site; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../../../src-tauri/icons/icon.ico",
      "../../../src-tauri/icons/icon.icns",
      "../../../src-tauri/icons/icon.png"
    ],
    "resources": []
  }
}
