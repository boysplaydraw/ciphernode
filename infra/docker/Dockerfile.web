FROM node:22-alpine AS build
WORKDIR /app
ENV ELECTRON_SKIP_BINARY_DOWNLOAD=1
ARG EXPO_PUBLIC_SERVER_URL=http://localhost:5000
ARG EXPO_PUBLIC_RELAY_TRANSPORT=websocket
ENV EXPO_PUBLIC_SERVER_URL=$EXPO_PUBLIC_SERVER_URL
ENV EXPO_PUBLIC_RELAY_TRANSPORT=$EXPO_PUBLIC_RELAY_TRANSPORT
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run electron:build:web

FROM nginx:1.27-alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY infra/docker/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
