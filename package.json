{
  "name": "ciphernode",
  "version": "1.0.0",
  "description": "End-to-end encrypted, anonymous messaging with Tor support",
  "author": "CipherNode",
  "main": "client/index.js",
  "scripts": {
    "expo:dev": "EXPO_PACKAGER_PROXY_URL=https://$REPLIT_DEV_DOMAIN REACT_NATIVE_PACKAGER_HOSTNAME=$REPLIT_DEV_DOMAIN EXPO_PUBLIC_DOMAIN=$REPLIT_DEV_DOMAIN:5000 npx expo start --localhost",
    "server:dev": "cross-env NODE_ENV=development tsx server/index.ts",
    "expo:start:static:build": "npx expo start --no-dev --minify --localhost",
    "expo:static:build": "node scripts/build.js",
    "server:build": "esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=server_dist",
    "server:prod": "NODE_ENV=production node server_dist/index.js",
    "db:push": "drizzle-kit push",
    "build:apk:preview": "eas build --platform android --profile preview",
    "build:apk:production": "eas build --platform android --profile production",
    "lint": "npx expo lint",
    "lint:fix": "npx expo lint --fix",
    "check:types": "tsc --noEmit",
    "check:format": "prettier --check \"**/*.{js,ts,tsx,css,json}\"",
    "format": "prettier --write \"**/*.{js,ts,tsx,css,json}\"",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web:dev": "concurrently \"npm run server:dev\" \"npx expo start --web --port 8081\"",
    "electron:dev": "concurrently \"npm run server:dev\" \"npx expo start --web\" \"wait-on http://localhost:8081 && electron .\"",
    "electron:build:web": "npx expo export --platform web --output-dir dist",
    "electron:compile": "tsc --project electron/tsconfig.json",
    "electron:pack": "npm run electron:build:web && npm run electron:compile && electron-builder --config electron/electron-builder.json",
    "electron:win": "npm run electron:pack -- --win",
    "electron:mac": "npm run electron:pack -- --mac",
    "electron:linux": "npm run electron:pack -- --linux",
    "build:ios": "eas build --platform ios",
    "build:ios:sim": "eas build --platform ios --profile preview"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@react-navigation/native-stack": "^7.3.16",
    "@tanstack/react-query": "^5.90.7",
    "drizzle-orm": "^0.39.3",
    "drizzle-zod": "^0.7.0",
    "expo": "^54.0.23",
    "expo-blur": "^15.0.7",
    "expo-build-properties": "^1.0.10",
    "expo-camera": "^17.0.10",
    "expo-clipboard": "^8.0.8",
    "expo-constants": "~18.0.9",
    "expo-crypto": "^15.0.8",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.9",
    "expo-glass-effect": "~0.1.6",
    "expo-haptics": "~15.0.7",
    "expo-image": "~3.0.10",
    "expo-image-manipulator": "~14.0.8",
    "expo-linking": "~8.0.8",
    "expo-local-authentication": "^17.0.8",
    "expo-sharing": "^14.0.8",
    "expo-splash-screen": "~31.0.10",
    "expo-status-bar": "~3.0.8",
    "expo-symbols": "~1.0.7",
    "expo-system-ui": "~6.0.8",
    "expo-web-browser": "~15.0.9",
    "express": "^4.21.2",
    "http-proxy-middleware": "^3.0.5",
    "openpgp": "^6.3.0",
    "pg": "^8.16.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-get-random-values": "^2.0.0",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-quick-crypto": "^1.0.6",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.20.6",
    "ws": "^8.18.0",
    "zod": "^3.24.2",
    "zod-validation-error": "^3.4.0"
  },
  "devDependencies": {
    "@types/electron": "^1.6.12",
    "@types/express": "^4.17.21",
    "@types/node": "24.10.0",
    "@types/react": "~19.1.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.4",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-node": "^0.3.9",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "3.6.2",
    "typescript": "~5.9.2",
    "wait-on": "^8.0.5"
  },
  "private": true,
  "electron": {
    "main": "electron/dist/main.js",
    "preload": "electron/dist/preload.js"
  }
}
